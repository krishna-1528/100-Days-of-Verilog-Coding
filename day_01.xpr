//Source Code

`timescale 1ns / 1ps

module and_gate( input a,b, output y
  );
  
  assign y = a & b;
  
endmodule




//TestBench Code

`timescale 1ns / 1ps

module tb();

reg p, q;
wire z;


and_gate dut(.a(p), .b(q), .y(z));

initial begin
  
    $display("Time Input1 Input2 Output");
    $monitor("%0t,%b, %b, %b", $time, p, q, z); 

   
    p = 0; q = 0; #10;
    p = 0; q = 1; #10;
    p = 1; q = 0; #10;
    p = 1; q = 1; #10;
    
     $finish;
end

endmodule
